# Core
APP_ENV=dev
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg2://valuebet:valuebet@db:5432/valuebet_iq
POSTGRES_DB=valuebet_iq
POSTGRES_USER=valuebet
POSTGRES_PASSWORD=valuebet

# Provider
ODDS_PROVIDER_MODE=mock
ODDS_API_KEY=
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ODDS_API_SPORTS=soccer_fifa_world_cup
ODDS_PROVIDER_REGION=us
ODDS_PROVIDER_MARKET_TYPES=h2h,totals,btts
ODDS_POLL_INTERVAL_SECONDS=60
MOCK_SEED_PATH=data/mock/mock_odds.json
WORLD_CUP_ONLY=true
WORLD_CUP_LEAGUE_NAME=FIFA World Cup
NEWS_ENABLED=true
WEATHER_ENABLED=true
NEWS_LOOKBACK_DAYS=7

# Risk + model defaults
DATA_FRESHNESS_SECONDS=180
MAX_ODDS_DRIFT_PCT=0.03
MIN_EDGE=0.015
TOP_PICK_EDGE=0.04
MIN_EV=0.02
TOP_PICK_EV=0.06
BANKROLL_START=1000
DEFAULT_FLAT_STAKE=25
MAX_STAKE=100
MAX_EXPOSURE_PER_EVENT=200
MAX_DAILY_LOSS=250

# Execution
SIM_SLIPPAGE_BPS=30
SIM_DELAY_MS=250
ENABLE_LIVE_EXECUTION=false
LIVE_BETFAIR_ENABLED=false
LIVE_MATCHBOOK_ENABLED=false

# Dashboard
API_BASE_URL=http://backend:8000/api
